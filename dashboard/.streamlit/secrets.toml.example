# Токен бота для получения username-ов через Telegram Bot API (getChat).
# Скопируй значение BOT_TOKEN из основного .env бота.
bot_token = "your_telegram_bot_token"

# Скопируй в secrets.toml и при необходимости укажи другой путь к БД.
# Файл bot.db по умолчанию кладётся в dashboard/data/bot.db
[connections.bot_db]
url = "sqlite:///data/bot.db"