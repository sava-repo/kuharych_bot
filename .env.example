BOT_TOKEN=your_telegram_bot_token
GLM_API_KEY=your_glm_api_key
GROQ_API_KEY=your_groq_api_key
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPO=sava-repo/new-catalog-2
WHITELIST_CHAT_IDS=252952086
# Lobstr.io API — основной источник описаний для Instagram Reels
# Получить: https://app.lobstr.io/dashboard/api
LOBSTR_API_KEY=your_lobstr_api_key
# Instagram cookies (Netscape format)
# Экспортируйте cookies из браузера — см. COOKIES_GUIDE.md
INSTAGRAM_COOKIES_FILE=data/instagram_cookies.txt
LOG_LEVEL=INFO

# Admin access for test commands (comma-separated user IDs)
# Only these users can run /run_tests command
ADMIN_IDS=252952086

# Testing environment: 'local' or 'server'
# local: integration tests are skipped (default)
# server: integration tests run with real API calls
TESTING_ENV=local
